# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/

# Editors / OS
.DS_Store
.idea/
.vscode/

# Build / dist
build/
dist/

# Experiment outputs: ignore heavy binaries, track CSV/JSON/PDF so the
# paper's numeric evidence and figures can be reproduced from the repo.
checkpoints/*.pt
checkpoints/*.metric.pt
results/**/*.png
results/**/*.npz
!checkpoints/.gitkeep
!results/.gitkeep
!results/exp1/.gitkeep
!results/scaling/.gitkeep

# Logs and overnight-run artifacts
*.log
logs/
wandb/

# Jupyter
.ipynb_checkpoints/
